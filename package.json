{
  "name": "resource-sniffer",
  "version": "0.1.0",
  "description": "A Chrome extension (MV3) that sniffs all resources used by a webpage.",
  "private": true,
  "scripts": {
    "build": "tsc && node scripts/copy-static.mjs",
    "watch": "tsc -w",
    "clean": "rm -rf dist"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "sharp": "^0.33.5",
    "typescript": "^6.0.3"
  }
}
