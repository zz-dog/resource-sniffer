{
  "name": "resource-sniffer",
  "version": "0.1.0",
  "description": "A Chrome extension (MV3) that sniffs all resources used by a webpage.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
