    "clean": "rm -rf dist"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^25.9.1",
    "sharp": "^0.33.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
